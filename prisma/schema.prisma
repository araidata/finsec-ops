model PurchaseItem {
  id                  String                     @id @default(uuid())
  purchaseId          String
  productId           String
  productModuleId     String?
  description         String?                    @db.Text
  quantity            Decimal?                   @db.Decimal(14, 2)
  quantityType        LicenseMetric?
  unitCost            Decimal?                   @db.Decimal(14, 2)
  totalCost           Decimal                    @default(0) @db.Decimal(14, 2)
  recurringCost       Decimal?                   @db.Decimal(14, 2)
  implementationCost  Decimal?                   @db.Decimal(14, 2)
  licenseStartsOn     DateTime?                  @db.Date
  licenseEndsOn       DateTime?                  @db.Date
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  purchase            Purchase                   @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product             Product                    @relation(fields: [productId], references: [id])
  productModule       ProductModule?             @relation(fields: [productModuleId], references: [id], onDelete: SetNull)
  features            PurchaseItemFeature[]
  deployments         Deployment[]
  budgetAllocations   PurchaseBudgetAllocation[]
  maintenanceRenewals MaintenanceRenewal[]

  @@index([purchaseId])
  @@index([productId])
  @@index([productModuleId])
}

model PurchaseItemFeature {
  purchaseItemId String
  featureId      String
  included       Boolean        @default(true)
  purchaseItem   PurchaseItem   @relation(fields: [purchaseItemId], references: [id], onDelete: Cascade)
  feature        ProductFeature @relation(fields: [featureId], references: [id])

  @@id([purchaseItemId, featureId])
  @@index([featureId])
}

model PurchaseBudgetAllocation {
  id                      String                 @id @default(uuid())
  purchaseId              String
  purchaseItemId          String?
  fiscalYearId            String
  budgetItemId            String?
  budgetAnnualFinancialId String?
  currencyCode            String                 @default("USD")
  allocatedAmount         Decimal                @default(0) @db.Decimal(14, 2)
  notesText               String?                @db.Text
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  purchase                Purchase               @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  purchaseItem            PurchaseItem?          @relation(fields: [purchaseItemId], references: [id], onDelete: Cascade)
  fiscalYear              FiscalYear             @relation(fields: [fiscalYearId], references: [id])
  budgetItem              BudgetItem?            @relation(fields: [budgetItemId], references: [id], onDelete: SetNull)
  budgetAnnualFinancial   BudgetAnnualFinancial? @relation(fields: [budgetAnnualFinancialId], references: [id], onDelete: SetNull)

  @@index([purchaseId])
  @@index([purchaseItemId])
  @@index([fiscalYearId])
  @@index([budgetItemId])
  @@index([budgetAnnualFinancialId])
}

model Deployment {
  id                 String             @id @default(uuid())
  purchaseItemId     String
  status             DeploymentStatus
  scopeName          String
  environment        String?
  department         String?
  wave               String?
  deploymentPercent  Decimal            @default(0) @db.Decimal(5, 2)
  targetPopulation   Int?
  deployedPopulation Int?
  adoptionLevel      AdoptionLevel?
  businessOwnerId    String?
  technicalOwnerId   String?
  securityOwnerId    String?
  targetDate         DateTime?          @db.Date
  completedDate      DateTime?          @db.Date
  blockers           String?            @db.Text
  expectedOutcome    String?            @db.Text
  realizedOutcome    String?            @db.Text
  valueNarrative     String?            @db.Text
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  purchaseItem       PurchaseItem       @relation(fields: [purchaseItemId], references: [id], onDelete: Cascade)
  businessOwner      User?              @relation("DeploymentBusinessOwner", fields: [businessOwnerId], references: [id], onDelete: SetNull)
  technicalOwner     User?              @relation("DeploymentTechnicalOwner", fields: [technicalOwnerId], references: [id], onDelete: SetNull)
  securityOwner      User?              @relation("DeploymentSecurityOwner", fields: [securityOwnerId], references: [id], onDelete: SetNull)
  usageMeasurements  UsageMeasurement[]

  @@index([purchaseItemId])
  @@index([status])
  @@index([businessOwnerId])
  @@index([technicalOwnerId])
  @@index([securityOwnerId])
}

model UsageMeasurement {
  id                 String     @id @default(uuid())
  deploymentId       String
  measuredAt         DateTime
  licensedCount      Int?
  deployedCount      Int?
  activeUsageCount   Int?
  utilizationPercent Decimal?   @db.Decimal(5, 2)
  source             String?
  notesText          String?    @db.Text
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deployment         Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@index([deploymentId, measuredAt])
}

model Renewal {
  id               String            @id @default(uuid())
  contractId       String
  fiscalYearId     String
  ownerId          String?
  title            String
  stage            RenewalStage      @default(NOT_STARTED)
  status           RenewalStatus     @default(PLANNED)
  renewalDate      DateTime          @db.Date
  noticeDate       DateTime?         @db.Date
  currencyCode     String            @default("USD")
  exposureAmount   Decimal           @default(0) @db.Decimal(14, 2)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  contract         Contract          @relation(fields: [contractId], references: [id])
  fiscalYear       FiscalYear        @relation(fields: [fiscalYearId], references: [id])
  owner            User?             @relation("RenewalOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  products         Product[]         @relation("RenewalProducts")
  productModules   ProductModule[]   @relation("RenewalProductModules")
  purchaseRequests PurchaseRequest[]
  budgetLineItems  BudgetLineItem[]
  invoices         Invoice[]
  payments         Payment[]
  documents        Document[]
  notes            Note[]

  @@index([contractId])
  @@index([fiscalYearId, status])
  @@index([renewalDate])
}

model PurchaseRequest {
  id              String                @id @default(uuid())
  fiscalYearId    String
  vendorId        String?
  resellerId      String?
  vendorCompanyId String?
  sellerCompanyId String?
  contractId      String?
  productId       String?
  productModuleId String?
