generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BudgetStatus {
  PLANNED
  REQUESTED
  APPROVED
  PARTIALLY_APPROVED
  DEFERRED
  REJECTED
  UNFUNDED
}

enum ExpenseType {
  HARDWARE
  SOFTWARE_SAAS
  SUBSCRIPTION
  MANAGED_SERVICE
  PROFESSIONAL_SERVICE
  CONSULTING
  TRAINING
  CERTIFICATION
  SUPPORT_MAINTENANCE
  CLOUD_INFRASTRUCTURE
  ONE_TIME_PURCHASE
  OTHER
}

enum FundingType {
  BASELINE
  RENEWAL
  NEW_CAPABILITY
  EXPANSION
  TRUE_UP
  GRANT
}

enum ContractStatus {
  ACTIVE
  PENDING
  RENEWING
  EXPIRING_SOON
  EXPIRED
  TERMINATED
}

enum ContractType {
  SOFTWARE
  SAAS
  HARDWARE
  PROFESSIONAL_SERVICES
  MANAGED_SERVICES
  SUPPORT
  MAINTENANCE
  TRAINING
  CERTIFICATION
  OTHER
}

enum PaymentFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
  MULTI_YEAR
  ONE_TIME
}

enum RenewalRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProductCategory {
  ENDPOINT_SECURITY
  IDENTITY_ACCESS
  NETWORK_SECURITY
  CLOUD_SECURITY
  DATA_SECURITY
  APPLICATION_SECURITY
  SECURITY_OPERATIONS
  GOVERNANCE_RISK_COMPLIANCE
  VULNERABILITY_EXPOSURE_MANAGEMENT
  THREAT_INTELLIGENCE
  WORKFORCE_SECURITY_AWARENESS
  CYBERSECURITY_STAFF_TRAINING_DEVELOPMENT
  BACKUP_RESILIENCE
  ASSET_CONFIGURATION_MANAGEMENT
  MANAGED_SECURITY_SERVICES
  PROFESSIONAL_SERVICES
  OTHER
}

enum CapabilityCategory {
  SIEM
  SOAR
  EDR
  XDR
  MDR
  VULNERABILITY_MANAGEMENT
  EXPOSURE_MANAGEMENT
  IAM
  PAM
  MFA
  SSO
  EMAIL_SECURITY
  DNS_SECURITY
  SECURE_WEB_GATEWAY
  FIREWALL
  IPS
  CASB
  CNAPP
  CSPM
  CWPP
  DLP
  DSPM
  GRC
  THIRD_PARTY_RISK
  SECURITY_AWARENESS
  PHISHING_SIMULATION
  STAFF_TRAINING
  CERTIFICATION_TRAINING
  ASSET_INVENTORY
  MDM
  BACKUP
  THREAT_INTELLIGENCE
  DIGITAL_FORENSICS
  INCIDENT_RESPONSE
  OTHER
}

enum DeploymentStatus {
  PLANNED
  IMPLEMENTING
  ACTIVE
  PARTIALLY_DEPLOYED
  UNDER_REVIEW
  RETIRING
  RETIRED
}

enum StrategicValue {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Criticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AdoptionLevel {
  NOT_USED
  LOW
  MEDIUM
  HIGH
  FULLY_ADOPTED
}

enum RenewalStage {
  NOT_STARTED
  DISCOVERY
  BUSINESS_OWNER_REVIEW
  PROCUREMENT_REVIEW
  NEGOTIATION
  EXECUTIVE_REVIEW
  COMPLETE
}

enum RenewalStatus {
  PLANNED
  IN_PROGRESS
  APPROVED
  RENEWED
  DEFERRED
  CANCELED
}

enum PurchaseRequestStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ORDERED
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  RECEIVED
  APPROVED
  PARTIALLY_PAID
  PAID
  DISPUTED
  VOID
}

enum PaymentStatus {
  SCHEDULED
  PROCESSING
  PAID
  FAILED
  VOID
}

enum DocumentType {
  CONTRACT
  ORDER_FORM
  QUOTE
  INVOICE
  RENEWAL_NOTICE
  PURCHASE_REQUEST
  SECURITY_REVIEW
  OTHER
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  AMOUNT_CHANGE
  OWNER_CHANGE
}

model FiscalYear {
  id               String            @id @default(uuid())
  label            String            @unique
  startsOn         DateTime          @db.Date
  endsOn           DateTime          @db.Date
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  budgetCategories BudgetCategory[]
  budgetLineItems  BudgetLineItem[]
  renewals         Renewal[]
  purchaseRequests PurchaseRequest[]
  invoices         Invoice[]
  payments         Payment[]

  @@index([startsOn, endsOn])
}

model BudgetCategory {
  id              String           @id @default(uuid())
  fiscalYearId    String
  name            String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  fiscalYear      FiscalYear       @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  budgetLineItems BudgetLineItem[]

  @@unique([fiscalYearId, name])
  @@index([fiscalYearId])
}

model BudgetLineItem {
  id                    String           @id @default(uuid())
  fiscalYearId          String
  budgetCategoryId      String
  vendorId              String?
  resellerId            String?
  ownerId               String?
  contractId            String?
  productId             String?
  productModuleId       String?
  renewalId             String?
  purchaseRequestId     String?
  name                  String
  productOrService      String?
  description           String?
  status                BudgetStatus     @default(PLANNED)
  expenseType           ExpenseType
  fundingType           FundingType
  currencyCode          String           @default("USD")
  budgetedAmount        Decimal          @default(0) @db.Decimal(14, 2)
  approvedAmount        Decimal          @default(0) @db.Decimal(14, 2)
  forecastAmount        Decimal          @default(0) @db.Decimal(14, 2)
  committedAmount       Decimal          @default(0) @db.Decimal(14, 2)
  actualAmount          Decimal          @default(0) @db.Decimal(14, 2)
  businessJustification String?          @db.Text
  riskIfNotFunded       String?          @db.Text
  notesText             String?          @db.Text
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  fiscalYear            FiscalYear       @relation(fields: [fiscalYearId], references: [id])
  budgetCategory        BudgetCategory   @relation(fields: [budgetCategoryId], references: [id])
  vendor                Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  reseller              Reseller?        @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  owner                 User?            @relation("BudgetLineItemOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  contract              Contract?        @relation(fields: [contractId], references: [id], onDelete: SetNull)
  product               Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  productModule         ProductModule?   @relation(fields: [productModuleId], references: [id], onDelete: SetNull)
  renewal               Renewal?         @relation(fields: [renewalId], references: [id], onDelete: SetNull)
  purchaseRequest       PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id], onDelete: SetNull)
  notes                 Note[]

  @@index([fiscalYearId, status])
  @@index([budgetCategoryId])
  @@index([vendorId])
  @@index([resellerId])
  @@index([contractId])
  @@index([productId])
  @@index([productModuleId])
  @@index([renewalId])
  @@index([purchaseRequestId])
}

model Vendor {
  id               String            @id @default(uuid())
  name             String            @unique
  website          String?
  contactEmail     String?
  notes            Note[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  products         Product[]
  contracts        Contract[]        @relation("ContractVendor")
  budgetLineItems  BudgetLineItem[]
  purchaseRequests PurchaseRequest[]
  invoices         Invoice[]
  documents        Document[]
}

model Reseller {
  id               String            @id @default(uuid())
  name             String            @unique
  website          String?
  contactEmail     String?
  notes            Note[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  contracts        Contract[]        @relation("ContractReseller")
  budgetLineItems  BudgetLineItem[]
  products         Product[]
  purchaseRequests PurchaseRequest[]
  invoices         Invoice[]
  documents        Document[]
}

model Contract {
  id                         String            @id @default(uuid())
  vendorId                   String?
  resellerId                 String?
  ownerId                    String?
  contractNumber             String?           @unique
  title                      String
  contractType               ContractType      @default(SAAS)
  associatedProductOrService String?
  status                     ContractStatus    @default(PENDING)
  renewalDate                DateTime?         @db.Date
  autoRenewal                Boolean           @default(false)
  noticePeriodDays           Int               @default(60)
  annualValue                Decimal           @default(0) @db.Decimal(14, 2)
  currencyCode               String            @default("USD")
  totalValue                 Decimal           @default(0) @db.Decimal(14, 2)
  paymentFrequency           PaymentFrequency  @default(ANNUAL)
  businessOwner              String?
  securityOwner              String?
  procurementContact         String?
  vendorAccountManager       String?
  resellerAccountManager     String?
  renewalRiskLevel           RenewalRiskLevel  @default(LOW)
  renewalStrategy            String?           @db.Text
  notesText                  String?           @db.Text
  startsOn                   DateTime          @db.Date
  endsOn                     DateTime          @db.Date
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  vendor                     Vendor?           @relation("ContractVendor", fields: [vendorId], references: [id], onDelete: SetNull)
  reseller                   Reseller?         @relation("ContractReseller", fields: [resellerId], references: [id], onDelete: SetNull)
  owner                      User?             @relation("ContractOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  products                   Product[]         @relation("ContractProducts")
  productModules             ProductModule[]   @relation("ContractProductModules")
  renewals                   Renewal[]
  purchaseRequests           PurchaseRequest[]
  budgetLineItems            BudgetLineItem[]
  invoices                   Invoice[]
  payments                   Payment[]
  documents                  Document[]
  notes                      Note[]

  @@index([vendorId])
  @@index([resellerId])
  @@index([status])
  @@index([startsOn, endsOn])
}

model Product {
  id                 String             @id @default(uuid())
  vendorId           String
  resellerId         String?
  name               String
  productCategory    ProductCategory    @default(OTHER)
  capabilityCategory CapabilityCategory @default(OTHER)
  description        String?
  deploymentStatus   DeploymentStatus   @default(PLANNED)
  businessOwner      String?
  technicalOwner     String?
  securityOwner      String?
  primaryUseCase     String?            @db.Text
  strategicValue     StrategicValue     @default(MEDIUM)
  criticality        Criticality        @default(MEDIUM)
  annualCost         Decimal            @default(0) @db.Decimal(14, 2)
  notesText          String?            @db.Text
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  vendor             Vendor             @relation(fields: [vendorId], references: [id])
  reseller           Reseller?          @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  modules            ProductModule[]
  contracts          Contract[]         @relation("ContractProducts")
  renewals           Renewal[]          @relation("RenewalProducts")
  purchaseRequests   PurchaseRequest[]
  budgetLineItems    BudgetLineItem[]
  documents          Document[]
  notes              Note[]

  @@unique([vendorId, name])
  @@index([vendorId])
  @@index([resellerId])
  @@index([productCategory])
  @@index([capabilityCategory])
  @@index([deploymentStatus])
}

model ProductModule {
  id                 String             @id @default(uuid())
  productId          String
  name               String
  description        String?
  capabilityCategory CapabilityCategory @default(OTHER)
  enabled            Boolean            @default(true)
  adoptionLevel      AdoptionLevel      @default(MEDIUM)
  licenseCount       Int                @default(0)
  usedCount          Int                @default(0)
  moduleCost         Decimal            @default(0) @db.Decimal(14, 2)
  owner              String?
  notesText          String?            @db.Text
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  product            Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  contracts          Contract[]         @relation("ContractProductModules")
  renewals           Renewal[]          @relation("RenewalProductModules")
  purchaseRequests   PurchaseRequest[]
  budgetLineItems    BudgetLineItem[]
  documents          Document[]
  notes              Note[]

  @@unique([productId, name])
  @@index([productId])
  @@index([capabilityCategory])
  @@index([adoptionLevel])
}

model Renewal {
  id               String            @id @default(uuid())
  contractId       String
  fiscalYearId     String
  ownerId          String?
  title            String
  stage            RenewalStage      @default(NOT_STARTED)
  status           RenewalStatus     @default(PLANNED)
  renewalDate      DateTime          @db.Date
  noticeDate       DateTime?         @db.Date
  currencyCode     String            @default("USD")
  exposureAmount   Decimal           @default(0) @db.Decimal(14, 2)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  contract         Contract          @relation(fields: [contractId], references: [id])
  fiscalYear       FiscalYear        @relation(fields: [fiscalYearId], references: [id])
  owner            User?             @relation("RenewalOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  products         Product[]         @relation("RenewalProducts")
  productModules   ProductModule[]   @relation("RenewalProductModules")
  purchaseRequests PurchaseRequest[]
  budgetLineItems  BudgetLineItem[]
  invoices         Invoice[]
  payments         Payment[]
  documents        Document[]
  notes            Note[]

  @@index([contractId])
  @@index([fiscalYearId, status])
  @@index([renewalDate])
}

model PurchaseRequest {
  id              String                @id @default(uuid())
  fiscalYearId    String
  vendorId        String?
  resellerId      String?
  contractId      String?
  productId       String?
  productModuleId String?
  renewalId       String?
  ownerId         String?
  requestNumber   String?               @unique
  title           String
  status          PurchaseRequestStatus @default(DRAFT)
  currencyCode    String                @default("USD")
  requestAmount   Decimal               @default(0) @db.Decimal(14, 2)
  approvedAmount  Decimal               @default(0) @db.Decimal(14, 2)
  submittedAt     DateTime?
  approvedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  fiscalYear      FiscalYear            @relation(fields: [fiscalYearId], references: [id])
  vendor          Vendor?               @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  reseller        Reseller?             @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  contract        Contract?             @relation(fields: [contractId], references: [id], onDelete: SetNull)
  product         Product?              @relation(fields: [productId], references: [id], onDelete: SetNull)
  productModule   ProductModule?        @relation(fields: [productModuleId], references: [id], onDelete: SetNull)
  renewal         Renewal?              @relation(fields: [renewalId], references: [id], onDelete: SetNull)
  owner           User?                 @relation("PurchaseRequestOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  budgetLineItems BudgetLineItem[]
  invoices        Invoice[]
  payments        Payment[]
  documents       Document[]
  notes           Note[]

  @@index([fiscalYearId, status])
  @@index([vendorId])
  @@index([resellerId])
  @@index([contractId])
  @@index([renewalId])
}

model Invoice {
  id                String           @id @default(uuid())
  fiscalYearId      String
  vendorId          String?
  resellerId        String?
  contractId        String?
  renewalId         String?
  purchaseRequestId String?
  invoiceNumber     String           @unique
  status            InvoiceStatus    @default(RECEIVED)
  currencyCode      String           @default("USD")
  amount            Decimal          @default(0) @db.Decimal(14, 2)
  issuedOn          DateTime         @db.Date
  dueOn             DateTime?        @db.Date
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  fiscalYear        FiscalYear       @relation(fields: [fiscalYearId], references: [id])
  vendor            Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  reseller          Reseller?        @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  contract          Contract?        @relation(fields: [contractId], references: [id], onDelete: SetNull)
  renewal           Renewal?         @relation(fields: [renewalId], references: [id], onDelete: SetNull)
  purchaseRequest   PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id], onDelete: SetNull)
  payments          Payment[]
  documents         Document[]
  notes             Note[]

  @@index([fiscalYearId, status])
  @@index([vendorId])
  @@index([resellerId])
  @@index([contractId])
  @@index([renewalId])
  @@index([purchaseRequestId])
}

model Payment {
  id                String           @id @default(uuid())
  fiscalYearId      String
  invoiceId         String?
  contractId        String?
  renewalId         String?
  purchaseRequestId String?
  status            PaymentStatus    @default(SCHEDULED)
  currencyCode      String           @default("USD")
  amount            Decimal          @default(0) @db.Decimal(14, 2)
  reference         String?
  paidOn            DateTime?        @db.Date
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  fiscalYear        FiscalYear       @relation(fields: [fiscalYearId], references: [id])
  invoice           Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  contract          Contract?        @relation(fields: [contractId], references: [id], onDelete: SetNull)
  renewal           Renewal?         @relation(fields: [renewalId], references: [id], onDelete: SetNull)
  purchaseRequest   PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id], onDelete: SetNull)

  @@index([fiscalYearId, status])
  @@index([invoiceId])
  @@index([contractId])
  @@index([renewalId])
  @@index([purchaseRequestId])
}

model Document {
  id                String           @id @default(uuid())
  uploadedById      String?
  vendorId          String?
  resellerId        String?
  contractId        String?
  renewalId         String?
  purchaseRequestId String?
  invoiceId         String?
  productId         String?
  productModuleId   String?
  type              DocumentType
  title             String
  url               String
  description       String?
  uploadedAt        DateTime         @default(now())
  uploadedBy        User?            @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  vendor            Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  reseller          Reseller?        @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  contract          Contract?        @relation(fields: [contractId], references: [id], onDelete: SetNull)
  renewal           Renewal?         @relation(fields: [renewalId], references: [id], onDelete: SetNull)
  purchaseRequest   PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id], onDelete: SetNull)
  invoice           Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  product           Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  productModule     ProductModule?   @relation(fields: [productModuleId], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([resellerId])
  @@index([contractId])
  @@index([renewalId])
  @@index([purchaseRequestId])
  @@index([invoiceId])
  @@index([productId])
  @@index([productModuleId])
}

model ActivityLog {
  id            String         @id @default(uuid())
  actorId       String?
  action        ActivityAction
  entityType    String
  entityId      String
  fieldName     String?
  previousValue String?        @db.Text
  newValue      String?        @db.Text
  amountBefore  Decimal?       @db.Decimal(14, 2)
  amountAfter   Decimal?       @db.Decimal(14, 2)
  metadata      Json?
  occurredAt    DateTime       @default(now())
  actor         User?          @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([action])
  @@index([occurredAt])
}

model User {
  id                    String            @id @default(uuid())
  email                 String            @unique
  name                  String
  role                  String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  ownedBudgetLineItems  BudgetLineItem[]  @relation("BudgetLineItemOwner")
  ownedContracts        Contract[]        @relation("ContractOwner")
  ownedRenewals         Renewal[]         @relation("RenewalOwner")
  ownedPurchaseRequests PurchaseRequest[] @relation("PurchaseRequestOwner")
  uploadedDocuments     Document[]        @relation("DocumentUploader")
  activityLogs          ActivityLog[]     @relation("ActivityActor")
  notes                 Note[]            @relation("NoteAuthor")
}

model Note {
  id                String           @id @default(uuid())
  authorId          String?
  vendorId          String?
  resellerId        String?
  contractId        String?
  renewalId         String?
  purchaseRequestId String?
  invoiceId         String?
  productId         String?
  productModuleId   String?
  budgetLineItemId  String?
  body              String           @db.Text
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  author            User?            @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  vendor            Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  reseller          Reseller?        @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  contract          Contract?        @relation(fields: [contractId], references: [id], onDelete: SetNull)
  renewal           Renewal?         @relation(fields: [renewalId], references: [id], onDelete: SetNull)
  purchaseRequest   PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id], onDelete: SetNull)
  invoice           Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  product           Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  productModule     ProductModule?   @relation(fields: [productModuleId], references: [id], onDelete: SetNull)
  budgetLineItem    BudgetLineItem?  @relation(fields: [budgetLineItemId], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([resellerId])
  @@index([contractId])
  @@index([renewalId])
  @@index([purchaseRequestId])
  @@index([invoiceId])
  @@index([productId])
  @@index([productModuleId])
  @@index([budgetLineItemId])
}
