  purchasingVehicle     PurchasingVehicle?         @relation(fields: [purchasingVehicleId], references: [id], onDelete: SetNull)
  purchasingAgreement   PurchasingVehicleSeller?   @relation(fields: [purchasingAgreementId], references: [id], onDelete: SetNull)
  purchaseRequest       PurchaseRequest?           @relation(fields: [purchaseRequestId], references: [id], onDelete: SetNull)
  items                 PurchaseItem[]
  budgetAllocations     PurchaseBudgetAllocation[]
  invoices              Invoice[]
  payments              Payment[]
  documents             Document[]
  notes                 Note[]

  @@index([fiscalYearId, status])
