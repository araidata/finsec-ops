model FiscalYear {
  id                        String                     @id @default(uuid())
  label                     String                     @unique
  startsOn                  DateTime                   @db.Date
  endsOn                    DateTime                   @db.Date
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  budgetCategories          BudgetCategory[]
  budgetLineItems           BudgetLineItem[]
  budgetPlans               BudgetPlan[]
  annualFinancials          BudgetAnnualFinancial[]
  maintenanceRenewals       MaintenanceRenewal[]
  renewals                  Renewal[]
  purchaseRequests          PurchaseRequest[]
  purchases                 Purchase[]
  purchaseBudgetAllocations PurchaseBudgetAllocation[]
  invoices                  Invoice[]
  payments                  Payment[]

  @@index([startsOn, endsOn])
}

model BudgetCategory {
  id              String           @id @default(uuid())
  fiscalYearId    String
  name            String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  fiscalYear      FiscalYear       @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  budgetLineItems BudgetLineItem[]

  @@unique([fiscalYearId, name])
  @@index([fiscalYearId])
}

model BudgetPlan {
  id                  String                  @id @default(uuid())
  fiscalYearId        String
  name                String
  status              BudgetPlanStatus        @default(DRAFT)
  version             String
  priorFiscalYear     String?
  planningOwner       String
  submissionDueDate   DateTime?               @db.Date
  assumptions         String?                 @db.Text
  executiveNarrative  String?                 @db.Text
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  fiscalYear          FiscalYear              @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  scenarios           BudgetScenario[]
  annualFinancials    BudgetAnnualFinancial[]
  maintenanceRenewals MaintenanceRenewal[]
  savingsRecords      SavingsRecord[]

  @@unique([fiscalYearId, version])
  @@index([fiscalYearId, status])
}

model BudgetScenario {
  id               String                  @id @default(uuid())
  budgetPlanId     String
  label            BudgetScenarioLabel
  description      String?
  isActive         Boolean                 @default(false)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  budgetPlan       BudgetPlan              @relation(fields: [budgetPlanId], references: [id], onDelete: Cascade)
  annualFinancials BudgetAnnualFinancial[]

  @@unique([budgetPlanId, label])
  @@index([budgetPlanId, isActive])
}

model BudgetAccount {
  id                  String                  @id @default(uuid())
  code                String
  name                String
  defaultWorksheet    BudgetWorksheetType
  active              Boolean                 @default(true)
  sortOrder           Int                     @default(0)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  annualFinancials    BudgetAnnualFinancial[]
  maintenanceRenewals MaintenanceRenewal[]

  @@unique([code])
  @@index([active, sortOrder])
}

model Company {
  id                         String                    @id @default(uuid())
  name                       String                    @unique
  legalName                  String?
  website                    String?
  contactEmail               String?
  active                     Boolean                   @default(true)
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  roles                      CompanyRole[]
  vendorBudgetItems          BudgetItem[]              @relation("BudgetItemVendorCompany")
  sellerBudgetItems          BudgetItem[]              @relation("BudgetItemSellerCompany")
  vendorMaintenanceRenewals  MaintenanceRenewal[]      @relation("MaintenanceRenewalVendorCompany")
  sellerMaintenanceRenewals  MaintenanceRenewal[]      @relation("MaintenanceRenewalSellerCompany")
  vendorBudgetLineItems      BudgetLineItem[]          @relation("BudgetLineItemVendorCompany")
  sellerBudgetLineItems      BudgetLineItem[]          @relation("BudgetLineItemSellerCompany")
  vendorContracts            Contract[]                @relation("ContractVendorCompany")
  sellerContracts            Contract[]                @relation("ContractSellerCompany")
  vendorProducts             Product[]                 @relation("ProductVendorCompany")
  productSellerRelationships ProductSeller[]           @relation("ProductSellerCompany")
  vehicleSellerRelationships PurchasingVehicleSeller[] @relation("VehicleSellerCompany")
  purchaseSellerRecords      Purchase[]                @relation("PurchaseSellerCompany")
  vendorPurchaseRequests     PurchaseRequest[]         @relation("PurchaseRequestVendorCompany")
  sellerPurchaseRequests     PurchaseRequest[]         @relation("PurchaseRequestSellerCompany")
  vendorInvoices             Invoice[]                 @relation("InvoiceVendorCompany")
  sellerInvoices             Invoice[]                 @relation("InvoiceSellerCompany")
  documents                  Document[]                @relation("DocumentCompany")
  notes                      Note[]                    @relation("NoteCompany")

  @@index([active])
}

model CompanyRole {
  id        String          @id @default(uuid())
  companyId String
  role      CompanyRoleType
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, role])
  @@index([role])
}

model Capability {
  id               String                     @id @default(uuid())
  name             String                     @unique
  description      String?                    @db.Text
  active           Boolean                    @default(true)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  products         ProductCapability[]
  modules          ProductModuleCapability[]
  features         ProductFeatureCapability[]
  primaryFunctions ProductFeature[]           @relation("ProductFunctionPrimaryCapability")

  @@index([active])
}

model PurchasingVehicle {
  id                  String                    @id @default(uuid())
  name                String
  contractNumber      String?
  issuingOrganization String?
  startsOn            DateTime?                 @db.Date
  endsOn              DateTime?                 @db.Date
  active              Boolean                   @default(true)
  notesText           String?                   @db.Text
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  sellerEligibility   PurchasingVehicleSeller[]
  purchases           Purchase[]

  @@unique([name, contractNumber])
  @@index([active])
  @@index([endsOn])
}

model PurchasingVehicleSeller {
  id                  String                                @id @default(uuid())
  purchasingVehicleId String
  sellerCompanyId     String
  sellerAwardNumber   String?
  title               String?
  startsOn            DateTime?                             @db.Date
  endsOn              DateTime?                             @db.Date
  active              Boolean                               @default(true)
  notesText           String?                               @db.Text
  createdAt           DateTime                              @default(now())
  updatedAt           DateTime                              @updatedAt
  purchasingVehicle   PurchasingVehicle                     @relation(fields: [purchasingVehicleId], references: [id], onDelete: Cascade)
  seller              Company                               @relation("VehicleSellerCompany", fields: [sellerCompanyId], references: [id])
  productEligibility  PurchasingVehicleProductEligibility[]
  purchases           Purchase[]

  @@unique([purchasingVehicleId, sellerCompanyId])
  @@index([sellerCompanyId])
  @@index([active])
  @@index([endsOn])
}

model PurchasingVehicleProductEligibility {
  id                        String                  @id @default(uuid())
  purchasingVehicleSellerId String
  productId                 String?
  productModuleId           String?
  awardNumber               String?
  startsOn                  DateTime?               @db.Date
  endsOn                    DateTime?               @db.Date
  active                    Boolean                 @default(true)
  notesText                 String?                 @db.Text
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  vehicleSeller             PurchasingVehicleSeller @relation(fields: [purchasingVehicleSellerId], references: [id], onDelete: Cascade)
  product                   Product?                @relation(fields: [productId], references: [id], onDelete: Cascade)
  productModule             ProductModule?          @relation(fields: [productModuleId], references: [id], onDelete: Cascade)

  @@index([purchasingVehicleSellerId])
  @@index([productId])
  @@index([productModuleId])
  @@index([active])
}

model BudgetItem {
  id                        String                     @id @default(uuid())
  vendorId                  String?
  resellerId                String?
  vendorCompanyId           String?
  sellerCompanyId           String?
  contractId                String?
  productId                 String?
  productModuleId           String?
  name                      String
  description               String?                    @db.Text
  owner                     String?
  strategicProgramArea      String?
  active                    Boolean                    @default(true)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  vendor                    Vendor?                    @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  reseller                  Reseller?                  @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  vendorCompany             Company?                   @relation("BudgetItemVendorCompany", fields: [vendorCompanyId], references: [id], onDelete: SetNull)
  sellerCompany             Company?                   @relation("BudgetItemSellerCompany", fields: [sellerCompanyId], references: [id], onDelete: SetNull)
  contract                  Contract?                  @relation(fields: [contractId], references: [id], onDelete: SetNull)
  product                   Product?                   @relation(fields: [productId], references: [id], onDelete: SetNull)
  productModule             ProductModule?             @relation(fields: [productModuleId], references: [id], onDelete: SetNull)
  annualFinancials          BudgetAnnualFinancial[]
  purchaseBudgetAllocations PurchaseBudgetAllocation[]

  @@index([vendorId])
  @@index([resellerId])
  @@index([vendorCompanyId])
  @@index([sellerCompanyId])
  @@index([contractId])
  @@index([productId])
  @@index([productModuleId])
  @@index([active])
}

model BudgetAnnualFinancial {
  id                        String                     @id @default(uuid())
  budgetPlanId              String
  scenarioId                String
  fiscalYearId              String
  budgetItemId              String
  accountId                 String
  worksheet                 BudgetWorksheetType
  sortOrder                 Int                        @default(0)
  currencyCode              String                     @default("USD")
  priorApprovedAmount       Decimal                    @default(0) @db.Decimal(14, 2)
  currentApprovedAmount     Decimal                    @default(0) @db.Decimal(14, 2)
  baseAmount                Decimal                    @default(0) @db.Decimal(14, 2)
  requestedAmount           Decimal                    @default(0) @db.Decimal(14, 2)
  proposedAmount            Decimal                    @default(0) @db.Decimal(14, 2)
  approvedAmount            Decimal                    @default(0) @db.Decimal(14, 2)
  revisedApprovedAmount     Decimal                    @default(0) @db.Decimal(14, 2)
  forecastAmount            Decimal                    @default(0) @db.Decimal(14, 2)
  encumberedAmount          Decimal                    @default(0) @db.Decimal(14, 2)
  actualAmount              Decimal                    @default(0) @db.Decimal(14, 2)
  unitCost                  Decimal                    @default(0) @db.Decimal(14, 2)
  quantity                  Decimal                    @default(1) @db.Decimal(14, 2)
  oneTimeAmount             Decimal                    @default(0) @db.Decimal(14, 2)
  recurringAmount           Decimal                    @default(0) @db.Decimal(14, 2)
  savingsAmount             Decimal                    @default(0) @db.Decimal(14, 2)
  costAvoidanceAmount       Decimal                    @default(0) @db.Decimal(14, 2)
  fundingStatus             BudgetFundingStatus        @default(DRAFT)
  recurrence                RecurringClassification    @default(RECURRING)
  reviewState               RowReviewState             @default(NEEDS_REVIEW)
  isNewRequest              Boolean                    @default(false)
  isRecurring               Boolean                    @default(true)
  isOneTime                 Boolean                    @default(false)
  isRetired                 Boolean                    @default(false)
  comments                  String?                    @db.Text
  businessJustification     String?                    @db.Text
  riskIfNotFunded           String?                    @db.Text
  complianceRequirement     String?
  owner                     String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  budgetPlan                BudgetPlan                 @relation(fields: [budgetPlanId], references: [id], onDelete: Cascade)
  scenario                  BudgetScenario             @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  fiscalYear                FiscalYear                 @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  budgetItem                BudgetItem                 @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)
  account                   BudgetAccount              @relation(fields: [accountId], references: [id])
  linkedMaintenanceRenewal  MaintenanceRenewal?        @relation("RenewalBudgetAnnual")
  savingsRecords            SavingsRecord[]
  purchaseBudgetAllocations PurchaseBudgetAllocation[]

  @@index([budgetPlanId, scenarioId])
  @@index([fiscalYearId])
  @@index([budgetItemId])
  @@index([accountId])
  @@index([worksheet])
}

model MaintenanceRenewal {
  id                      String                   @id @default(uuid())
  budgetPlanId            String
  fiscalYearId            String
  linkedAnnualFinancialId String?                  @unique
  vendorId                String?
  resellerId              String?
  vendorCompanyId         String?
  sellerCompanyId         String?
  contractId              String?
  productId               String?
  purchaseItemId          String?
  fundingAccountId        String
  productOrService        String
  currentAnnualCost       Decimal                  @default(0) @db.Decimal(14, 2)
  renewalQuote            Decimal                  @default(0) @db.Decimal(14, 2)
  negotiatedCost          Decimal                  @default(0) @db.Decimal(14, 2)
  renewalDate             DateTime                 @db.Date
  contractStart           DateTime?                @db.Date
  contractEnd             DateTime?                @db.Date
  noticePeriodDays        Int                      @default(60)
  noticeDate              DateTime?                @db.Date
  autoRenewal             Boolean                  @default(false)
  paymentFrequency        PaymentFrequency         @default(ANNUAL)
  renewalStatus           MaintenanceRenewalStatus @default(NOT_STARTED)
  procurementStatus       ProcurementStatus        @default(NOT_STARTED)
  quoteReceivedDate       DateTime?                @db.Date
  purchaseRequestNumber   String?
  purchaseOrderNumber     String?
  expectedPaymentDate     DateTime?                @db.Date
  renewalOwnerId          String?
  procurementOwnerId      String?
  renewalOwner            String?
  procurementOwner        String?
  renewalStrategy         String?                  @db.Text
  renewalRisk             RenewalRiskLevel         @default(LOW)
  notesText               String?                  @db.Text
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  budgetPlan              BudgetPlan               @relation(fields: [budgetPlanId], references: [id], onDelete: Cascade)
  fiscalYear              FiscalYear               @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
  linkedAnnualFinancial   BudgetAnnualFinancial?   @relation("RenewalBudgetAnnual", fields: [linkedAnnualFinancialId], references: [id], onDelete: SetNull)
  vendor                  Vendor?                  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  reseller                Reseller?                @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  vendorCompany           Company?                 @relation("MaintenanceRenewalVendorCompany", fields: [vendorCompanyId], references: [id], onDelete: SetNull)
  sellerCompany           Company?                 @relation("MaintenanceRenewalSellerCompany", fields: [sellerCompanyId], references: [id], onDelete: SetNull)
  contract                Contract?                @relation(fields: [contractId], references: [id], onDelete: SetNull)
  product                 Product?                 @relation(fields: [productId], references: [id], onDelete: SetNull)
  purchaseItem            PurchaseItem?            @relation(fields: [purchaseItemId], references: [id], onDelete: SetNull)
  renewalOwnerUser        User?                    @relation("MaintenanceRenewalOwner", fields: [renewalOwnerId], references: [id], onDelete: SetNull)
  procurementOwnerUser    User?                    @relation("MaintenanceRenewalProcurementOwner", fields: [procurementOwnerId], references: [id], onDelete: SetNull)
  fundingAccount          BudgetAccount            @relation(fields: [fundingAccountId], references: [id])
  savingsRecords          SavingsRecord[]

  @@index([budgetPlanId])
  @@index([fiscalYearId, renewalStatus])
  @@index([renewalDate])
  @@index([vendorCompanyId])
  @@index([sellerCompanyId])
  @@index([purchaseItemId])
  @@index([fundingAccountId])
}

model SavingsRecord {
  id                   String                 @id @default(uuid())
  budgetPlanId         String
  annualFinancialId    String?
  maintenanceRenewalId String?
  type                 SavingsType
  description          String                 @db.Text
  currencyCode         String                 @default("USD")
  amount               Decimal                @default(0) @db.Decimal(14, 2)
  costAvoidanceAmount  Decimal                @default(0) @db.Decimal(14, 2)
  isBudgetReduction    Boolean                @default(true)
  ownerId              String?
  owner                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  budgetPlan           BudgetPlan             @relation(fields: [budgetPlanId], references: [id], onDelete: Cascade)
  annualFinancial      BudgetAnnualFinancial? @relation(fields: [annualFinancialId], references: [id], onDelete: SetNull)
  maintenanceRenewal   MaintenanceRenewal?    @relation(fields: [maintenanceRenewalId], references: [id], onDelete: SetNull)
  ownerUser            User?                  @relation("SavingsRecordOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([budgetPlanId])
  @@index([annualFinancialId])
  @@index([maintenanceRenewalId])
  @@index([ownerId])
  @@index([type])
}

model BudgetLineItem {
  id                    String           @id @default(uuid())
  fiscalYearId          String
  budgetCategoryId      String
  vendorId              String?
  resellerId            String?
  vendorCompanyId       String?
  sellerCompanyId       String?
  ownerId               String?
  contractId            String?
  productId             String?
  productModuleId       String?
  renewalId             String?
  purchaseRequestId     String?
  name                  String
  productOrService      String?
  description           String?
  status                BudgetStatus     @default(PLANNED)
  expenseType           ExpenseType
  fundingType           FundingType
  currencyCode          String           @default("USD")
  budgetedAmount        Decimal          @default(0) @db.Decimal(14, 2)
  approvedAmount        Decimal          @default(0) @db.Decimal(14, 2)
  forecastAmount        Decimal          @default(0) @db.Decimal(14, 2)
  committedAmount       Decimal          @default(0) @db.Decimal(14, 2)
  actualAmount          Decimal          @default(0) @db.Decimal(14, 2)
  businessJustification String?          @db.Text
  riskIfNotFunded       String?          @db.Text
  notesText             String?          @db.Text
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  fiscalYear            FiscalYear       @relation(fields: [fiscalYearId], references: [id])
  budgetCategory        BudgetCategory   @relation(fields: [budgetCategoryId], references: [id])
  vendor                Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  reseller              Reseller?        @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  vendorCompany         Company?         @relation("BudgetLineItemVendorCompany", fields: [vendorCompanyId], references: [id], onDelete: SetNull)
  sellerCompany         Company?         @relation("BudgetLineItemSellerCompany", fields: [sellerCompanyId], references: [id], onDelete: SetNull)
  owner                 User?            @relation("BudgetLineItemOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  contract              Contract?        @relation(fields: [contractId], references: [id], onDelete: SetNull)
  product               Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  productModule         ProductModule?   @relation(fields: [productModuleId], references: [id], onDelete: SetNull)
  renewal               Renewal?         @relation(fields: [renewalId], references: [id], onDelete: SetNull)
  purchaseRequest       PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id], onDelete: SetNull)
  notes                 Note[]

  @@index([fiscalYearId, status])
  @@index([budgetCategoryId])
  @@index([vendorId])
  @@index([resellerId])
  @@index([vendorCompanyId])
  @@index([sellerCompanyId])
  @@index([contractId])
  @@index([productId])
  @@index([productModuleId])
  @@index([renewalId])
  @@index([purchaseRequestId])
}

model Vendor {
  id                  String               @id @default(uuid())
  name                String               @unique
  website             String?
  contactEmail        String?
  notes               Note[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  products            Product[]
  contracts           Contract[]           @relation("ContractVendor")
  budgetLineItems     BudgetLineItem[]
  purchaseRequests    PurchaseRequest[]
  invoices            Invoice[]
  documents           Document[]
  budgetItems         BudgetItem[]
  maintenanceRenewals MaintenanceRenewal[]
}

model Reseller {
  id                  String               @id @default(uuid())
  name                String               @unique
  website             String?
  contactEmail        String?
  notes               Note[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  contracts           Contract[]           @relation("ContractReseller")
  budgetLineItems     BudgetLineItem[]
  products            Product[]
  purchaseRequests    PurchaseRequest[]
  invoices            Invoice[]
  documents           Document[]
  budgetItems         BudgetItem[]
  maintenanceRenewals MaintenanceRenewal[]
}

model Contract {
  id                         String               @id @default(uuid())
  vendorId                   String?
  resellerId                 String?
  vendorCompanyId            String?
  sellerCompanyId            String?
  ownerId                    String?
  contractNumber             String?              @unique
  title                      String
  contractType               ContractType         @default(SAAS)
  associatedProductOrService String?
  status                     ContractStatus       @default(PENDING)
  renewalDate                DateTime?            @db.Date
  autoRenewal                Boolean              @default(false)
  noticePeriodDays           Int                  @default(60)
  annualValue                Decimal              @default(0) @db.Decimal(14, 2)
  currencyCode               String               @default("USD")
  totalValue                 Decimal              @default(0) @db.Decimal(14, 2)
  paymentFrequency           PaymentFrequency     @default(ANNUAL)
  businessOwner              String?
  securityOwner              String?
  procurementContact         String?
  vendorAccountManager       String?
  resellerAccountManager     String?
  renewalRiskLevel           RenewalRiskLevel     @default(LOW)
  renewalStrategy            String?              @db.Text
  notesText                  String?              @db.Text
  startsOn                   DateTime             @db.Date
  endsOn                     DateTime             @db.Date
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  vendor                     Vendor?              @relation("ContractVendor", fields: [vendorId], references: [id], onDelete: SetNull)
  reseller                   Reseller?            @relation("ContractReseller", fields: [resellerId], references: [id], onDelete: SetNull)
  vendorCompany              Company?             @relation("ContractVendorCompany", fields: [vendorCompanyId], references: [id], onDelete: SetNull)
  sellerCompany              Company?             @relation("ContractSellerCompany", fields: [sellerCompanyId], references: [id], onDelete: SetNull)
  owner                      User?                @relation("ContractOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  products                   Product[]            @relation("ContractProducts")
  productModules             ProductModule[]      @relation("ContractProductModules")
  renewals                   Renewal[]
  purchaseRequests           PurchaseRequest[]
  purchases                  Purchase[]
  budgetLineItems            BudgetLineItem[]
  invoices                   Invoice[]
  payments                   Payment[]
  documents                  Document[]
  notes                      Note[]
  budgetItems                BudgetItem[]
  maintenanceRenewals        MaintenanceRenewal[]

  @@index([vendorId])
  @@index([resellerId])
  @@index([vendorCompanyId])
  @@index([sellerCompanyId])
  @@index([status])
  @@index([startsOn, endsOn])
}

model Product {
  id                  String                                @id @default(uuid())
  vendorId            String
  resellerId          String?
  vendorCompanyId     String?
  name                String
  offeringType        ProductOfferingType                   @default(SAAS)
  productCategory     ProductCategory                       @default(OTHER)
  capabilityCategory  CapabilityCategory                    @default(OTHER)
  description         String?
  active              Boolean                               @default(true)
  deploymentStatus    DeploymentStatus                      @default(PLANNED)
  businessOwner       String?
  technicalOwner      String?
  securityOwner       String?
  primaryUseCase      String?                               @db.Text
  strategicValue      StrategicValue                        @default(MEDIUM)
  criticality         Criticality                           @default(MEDIUM)
  annualCost          Decimal                               @default(0) @db.Decimal(14, 2)
  notesText           String?                               @db.Text
  createdAt           DateTime                              @default(now())
  updatedAt           DateTime                              @updatedAt
  vendor              Vendor                                @relation(fields: [vendorId], references: [id])
  reseller            Reseller?                             @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  vendorCompany       Company?                              @relation("ProductVendorCompany", fields: [vendorCompanyId], references: [id], onDelete: SetNull)
  modules             ProductModule[]
  features            ProductFeature[]
  sellers             ProductSeller[]
  purchaseItems       PurchaseItem[]
  capabilities        ProductCapability[]
  vehicleEligibility  PurchasingVehicleProductEligibility[]
  contracts           Contract[]                            @relation("ContractProducts")
  renewals            Renewal[]                             @relation("RenewalProducts")
  purchaseRequests    PurchaseRequest[]
  budgetLineItems     BudgetLineItem[]
  documents           Document[]
  notes               Note[]
  budgetItems         BudgetItem[]
  maintenanceRenewals MaintenanceRenewal[]

  @@unique([vendorId, name])
  @@index([vendorId])
  @@index([resellerId])
  @@index([vendorCompanyId])
  @@index([offeringType])
  @@index([productCategory])
  @@index([capabilityCategory])
  @@index([deploymentStatus])
  @@index([active])
}

model ProductModule {
  id                    String                                @id @default(uuid())
  productId             String
  name                  String
  description           String?
  componentType         ProductComponentType                  @default(MODULE)
  sku                   String?
  licenseMetric         LicenseMetric?
  separatelyPurchasable Boolean                               @default(false)
  separatelyRenewable   Boolean                               @default(false)
  purpose               String?                               @db.Text
  lifecycleStatus       CatalogLifecycleStatus                @default(ACTIVE)
  planningEstimate      Decimal                               @default(0) @db.Decimal(14, 2)
  capabilityCategory    CapabilityCategory                    @default(OTHER)
  active                Boolean                               @default(true)
  enabled               Boolean                               @default(true)
  adoptionLevel         AdoptionLevel                         @default(MEDIUM)
  licenseCount          Int                                   @default(0)
  usedCount             Int                                   @default(0)
  moduleCost            Decimal                               @default(0) @db.Decimal(14, 2)
  owner                 String?
  notesText             String?                               @db.Text
  createdAt             DateTime                              @default(now())
  updatedAt             DateTime                              @updatedAt
  product               Product                               @relation(fields: [productId], references: [id], onDelete: Cascade)
  features              ProductFeature[]
  purchaseItems         PurchaseItem[]
  capabilities          ProductModuleCapability[]
  vehicleEligibility    PurchasingVehicleProductEligibility[]
  contracts             Contract[]                            @relation("ContractProductModules")
  renewals              Renewal[]                             @relation("RenewalProductModules")
  purchaseRequests      PurchaseRequest[]
  budgetLineItems       BudgetLineItem[]
  documents             Document[]
  notes                 Note[]
  budgetItems           BudgetItem[]

  @@unique([productId, name])
  @@index([productId])
  @@index([componentType])
  @@index([capabilityCategory])
  @@index([lifecycleStatus])
  @@index([adoptionLevel])
  @@index([active])
}

model ProductFeature {
  id                  String                     @id @default(uuid())
  productId           String
  moduleId            String?
  relatedCapabilityId String?
  name                String
  description         String?                    @db.Text
  strategicImportance StrategicValue?
  notesText           String?                    @db.Text
  active              Boolean                    @default(true)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  product             Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  module              ProductModule?             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  relatedCapability   Capability?                @relation("ProductFunctionPrimaryCapability", fields: [relatedCapabilityId], references: [id], onDelete: SetNull)
  purchaseFeatures    PurchaseItemFeature[]
  capabilities        ProductFeatureCapability[]

  @@index([productId])
  @@index([moduleId])
  @@index([relatedCapabilityId])
  @@index([active])
}

model ProductSeller {
  id               String                 @id @default(uuid())
  productId        String
  sellerCompanyId  String
  relationshipType SellerRelationshipType @default(RESELLER)
  preferred        Boolean                @default(false)
  sellerSku        String?
  active           Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  product          Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller           Company                @relation("ProductSellerCompany", fields: [sellerCompanyId], references: [id])

  @@unique([productId, sellerCompanyId])
  @@index([productId])
  @@index([sellerCompanyId])
  @@index([relationshipType])
  @@index([active])
}

model ProductCapability {
  productId          String
  capabilityId       String
  isPrimary          Boolean                    @default(false)
  allocationMethod   CapabilityAllocationMethod @default(UNALLOCATED)
  allocationGuidance String?                    @db.Text
  notesText          String?                    @db.Text
  product            Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  capability         Capability                 @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@id([productId, capabilityId])
  @@index([capabilityId])
}

model ProductModuleCapability {
  productModuleId    String
  capabilityId       String
  isPrimary          Boolean                    @default(false)
  allocationMethod   CapabilityAllocationMethod @default(UNALLOCATED)
  allocationGuidance String?                    @db.Text
  notesText          String?                    @db.Text
  productModule      ProductModule              @relation(fields: [productModuleId], references: [id], onDelete: Cascade)
  capability         Capability                 @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@id([productModuleId, capabilityId])
  @@index([capabilityId])
}

model ProductFeatureCapability {
  productFeatureId String
  capabilityId     String
  productFeature   ProductFeature @relation(fields: [productFeatureId], references: [id], onDelete: Cascade)
  capability       Capability     @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@id([productFeatureId, capabilityId])
  @@index([capabilityId])
}

model Purchase {
  id                    String                     @id @default(uuid())
  title                 String
  fiscalYearId          String
  sellerCompanyId       String?
  contractId            String?
  purchasingVehicleId   String?
  purchasingAgreementId String?
  purchaseRequestId     String?
  status                PurchaseStatus             @default(APPROVED)
  purchasingChannel     PurchasingChannel          @default(RESELLER)
  currencyCode          String                     @default("USD")
  totalAmount           Decimal                    @default(0) @db.Decimal(14, 2)
  quoteNumber           String?
