model Document {
  id                   String              @id @default(uuid())
  uploadedById         String?
  vendorId             String?
  resellerId           String?
  companyId            String?
  purchaseId           String?
  contractId           String?
  maintenanceRenewalId String?
  renewalId            String?
  purchaseRequestId    String?
  invoiceId            String?
  productId            String?
  productModuleId      String?
  type                 DocumentType
  title                String
  url                  String
  description          String?
  uploadedAt           DateTime            @default(now())
  uploadedBy           User?               @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  vendor               Vendor?             @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  reseller             Reseller?           @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  company              Company?            @relation("DocumentCompany", fields: [companyId], references: [id], onDelete: SetNull)
  purchase             Purchase?           @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  contract             Contract?           @relation(fields: [contractId], references: [id], onDelete: SetNull)
  maintenanceRenewal   MaintenanceRenewal? @relation(fields: [maintenanceRenewalId], references: [id], onDelete: SetNull)
  renewal              Renewal?            @relation(fields: [renewalId], references: [id], onDelete: SetNull)
  purchaseRequest      PurchaseRequest?    @relation(fields: [purchaseRequestId], references: [id], onDelete: SetNull)
  invoice              Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  product              Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  productModule        ProductModule?      @relation(fields: [productModuleId], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([resellerId])
  @@index([companyId])
  @@index([purchaseId])
  @@index([contractId])
  @@index([maintenanceRenewalId])
  @@index([renewalId])
  @@index([purchaseRequestId])
  @@index([invoiceId])
  @@index([productId])
  @@index([productModuleId])
}

model ActivityLog {
  id            String         @id @default(uuid())
  actorId       String?
  action        ActivityAction
  entityType    String
  entityId      String
  fieldName     String?
  previousValue String?        @db.Text
  newValue      String?        @db.Text
  amountBefore  Decimal?       @db.Decimal(14, 2)
  amountAfter   Decimal?       @db.Decimal(14, 2)
  metadata      Json?
  occurredAt    DateTime       @default(now())
  actor         User?          @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([action])
  @@index([occurredAt])
}

model User {
  id                          String               @id @default(uuid())
  email                       String               @unique
  name                        String
  role                        String?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  ownedBudgetLineItems        BudgetLineItem[]     @relation("BudgetLineItemOwner")
  ownedContracts              Contract[]           @relation("ContractOwner")
  ownedRenewals               Renewal[]            @relation("RenewalOwner")
  ownedMaintenanceRenewals    MaintenanceRenewal[] @relation("MaintenanceRenewalOwner")
  procuredMaintenanceRenewals MaintenanceRenewal[] @relation("MaintenanceRenewalProcurementOwner")
  ownedSavingsRecords         SavingsRecord[]      @relation("SavingsRecordOwner")
  ownedPurchaseRequests       PurchaseRequest[]    @relation("PurchaseRequestOwner")
  businessOwnedDeployments    Deployment[]         @relation("DeploymentBusinessOwner")
  technicalOwnedDeployments   Deployment[]         @relation("DeploymentTechnicalOwner")
  securityOwnedDeployments    Deployment[]         @relation("DeploymentSecurityOwner")
  uploadedDocuments           Document[]           @relation("DocumentUploader")
  activityLogs                ActivityLog[]        @relation("ActivityActor")
  notes                       Note[]               @relation("NoteAuthor")
}

model Note {
  id                   String              @id @default(uuid())
  authorId             String?
  vendorId             String?
  resellerId           String?
  companyId            String?
  purchaseId           String?
  contractId           String?
  maintenanceRenewalId String?
  renewalId            String?
  purchaseRequestId    String?
  invoiceId            String?
  productId            String?
  productModuleId      String?
  budgetLineItemId     String?
  body                 String              @db.Text
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  author               User?               @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  vendor               Vendor?             @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  reseller             Reseller?           @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  company              Company?            @relation("NoteCompany", fields: [companyId], references: [id], onDelete: SetNull)
  purchase             Purchase?           @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  contract             Contract?           @relation(fields: [contractId], references: [id], onDelete: SetNull)
  maintenanceRenewal   MaintenanceRenewal? @relation(fields: [maintenanceRenewalId], references: [id], onDelete: SetNull)
  renewal              Renewal?            @relation(fields: [renewalId], references: [id], onDelete: SetNull)
  purchaseRequest      PurchaseRequest?    @relation(fields: [purchaseRequestId], references: [id], onDelete: SetNull)
  invoice              Invoice?            @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  product              Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  productModule        ProductModule?      @relation(fields: [productModuleId], references: [id], onDelete: SetNull)
  budgetLineItem       BudgetLineItem?     @relation(fields: [budgetLineItemId], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([resellerId])
  @@index([companyId])
  @@index([purchaseId])
  @@index([contractId])
  @@index([maintenanceRenewalId])
  @@index([renewalId])
  @@index([purchaseRequestId])
  @@index([invoiceId])
  @@index([productId])
  @@index([productModuleId])
  @@index([budgetLineItemId])
}
