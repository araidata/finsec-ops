  notes                 Note[]

  @@index([fiscalYearId, status])
  @@index([sellerCompanyId])
  @@index([contractId])
  @@index([maintenanceRenewalId])
  @@index([purchasingVehicleId])
  @@index([purchasingAgreementId])
  @@index([purchaseRequestId])
}

model PurchaseItem {
  id                  String                     @id @default(uuid())
  purchaseId          String
  productId           String
  productModuleId     String?
  description         String?                    @db.Text
  quantity            Decimal?                   @db.Decimal(14, 2)
  quantityType        LicenseMetric?
  unitCost            Decimal?                   @db.Decimal(14, 2)
  totalCost           Decimal                    @default(0) @db.Decimal(14, 2)
  recurringCost       Decimal?                   @db.Decimal(14, 2)
  implementationCost  Decimal?                   @db.Decimal(14, 2)
  licenseStartsOn     DateTime?                  @db.Date
  licenseEndsOn       DateTime?                  @db.Date
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  purchase            Purchase                   @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
