  approvedAmount  Decimal               @default(0) @db.Decimal(14, 2)
  submittedAt     DateTime?
  approvedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  fiscalYear      FiscalYear            @relation(fields: [fiscalYearId], references: [id])
  vendor          Vendor?               @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  reseller        Reseller?             @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  vendorCompany   Company?              @relation("PurchaseRequestVendorCompany", fields: [vendorCompanyId], references: [id], onDelete: SetNull)
  sellerCompany   Company?              @relation("PurchaseRequestSellerCompany", fields: [sellerCompanyId], references: [id], onDelete: SetNull)
